{
  "id": "apothecary",
  "name": "薬屋の店主",
  "sprite": "apothecary",
  "dialogue": [
    {
      "if": [
        [
          [
            "quest_herb",
            "done"
          ]
        ],
        [
          [
            "met_dweller",
            "yes"
          ]
        ]
      ],
      "lines": [
        "森の住人にも会ったんだな。あの人の薬草は、いつも質がいい。"
      ]
    },
    {
      "if": [
        [
          [
            "quest_herb",
            "done"
          ]
        ]
      ],
      "lines": [
        "先日は助かったよ。よく効く薬ができそうだ。"
      ]
    },
    {
      "if": [
        [
          [
            "quest_herb",
            "collected"
          ]
        ]
      ],
      "lines": [
        "おお、薬草を採ってきてくれたか！ありがとう、助かるよ。"
      ],
      "set": [
        [
          "quest_herb",
          "done"
        ]
      ],
      "take": [
        "herb"
      ],
      "has": [
        "herb"
      ]
    },
    {
      "if": [
        [
          [
            "quest_herb",
            "started"
          ]
        ]
      ],
      "lines": [
        "薬草はまだかい？　東の森に生えているはずだよ。"
      ]
    },
    {
      "if": [
        [
          [
            "quest_herb",
            "none"
          ]
        ]
      ],
      "lines": [
        "いらっしゃい。……そうだ、東の森で薬草を採ってきてくれないか？"
      ],
      "choices": [
        {
          "label": "引き受ける",
          "lines": [
            "ありがとう、助かるよ。採れたら、また声をかけてくれ。"
          ],
          "set": [
            [
              "quest_herb",
              "started"
            ]
          ]
        },
        {
          "label": "今はやめておく",
          "lines": [
            "そうかい。気が向いたら、また来ておくれ。",
            "test"
          ]
        }
      ]
    }
  ]
}
