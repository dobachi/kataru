{
  "id": "apothecary",
  "name": "薬屋の店主",
  "sprite": "apothecary",
  "dialogue": [
    {
      "if": [
        "quest_herb",
        "done"
      ],
      "set": null,
      "lines": [
        "先日は助かったよ。よく効く薬ができそうだ。"
      ]
    },
    {
      "if": [
        "quest_herb",
        "collected"
      ],
      "set": [
        "quest_herb",
        "done"
      ],
      "lines": [
        "おお、薬草を採ってきてくれたか！ありがとう、助かるよ。"
      ]
    },
    {
      "if": [
        "quest_herb",
        "started"
      ],
      "set": null,
      "lines": [
        "薬草はまだかい？　東の森に生えているはずだよ。"
      ]
    },
    {
      "if": [
        "quest_herb",
        "none"
      ],
      "set": null,
      "lines": [
        "いらっしゃい。……そうだ、東の森で薬草を採ってきてくれないか？"
      ],
      "choices": [
        {
          "label": "引き受ける",
          "set": [
            "quest_herb",
            "started"
          ],
          "lines": [
            "ありがとう、助かるよ。採れたら、また声をかけてくれ。"
          ]
        },
        {
          "label": "今はやめておく",
          "set": null,
          "lines": [
            "そうかい。気が向いたら、また来ておくれ。"
          ]
        }
      ]
    }
  ]
}
